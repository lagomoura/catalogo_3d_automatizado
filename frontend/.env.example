# Base URL del backend FastAPI
VITE_API_BASE=http://localhost:8000

# Contraseña para acceder a /admin.
# IMPORTANTE: esta variable se incluye en el bundle de JS público.
# No es una barrera de seguridad real; solo evita el descubrimiento casual.
# Si la dejas vacía o no la defines, /admin será de acceso abierto.
VITE_ADMIN_PASSWORD=
