# Base URL del backend FastAPI
VITE_API_BASE=http://localhost:8000

# Dominio raíz del SaaS para derivar el slug de tienda desde el subdominio del
# browser (la vitrina pública vive en <slug>.<VITE_BASE_DOMAIN>). En dev usamos
# lvh.me (resuelve a 127.0.0.1) para poder probar subdominios localmente.
# Debe coincidir con BASE_DOMAIN del backend.
VITE_BASE_DOMAIN=lvh.me
